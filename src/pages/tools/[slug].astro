---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const t = tool.data;

const allPlans = await getCollection('plans');
// Find plans compatible with this tool
const compatiblePlans = allPlans.filter(p => p.data.compatible_tools.includes(t.slug));
---

<BaseLayout
  title={`${t.name} — Features & Plan Compatibility`}
  description={`${t.name}: ${t.description}. Compatible with ${compatiblePlans.length} AI coding plans. View features and plan compatibility.`}
>
  <Navbar />

  <main class="min-h-screen bg-base-200">
    <!-- Breadcrumbs -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
      <nav aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm">
          <li><a href="/" class="text-base-content/50 hover:text-primary transition-colors">Home</a></li>
          <li class="text-base-content/30">/</li>
          <li><a href="/tools" class="text-base-content/50 hover:text-primary transition-colors">Tools</a></li>
          <li class="text-base-content/30">/</li>
          <li class="font-medium">{t.name}</li>
        </ol>
      </nav>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Header -->
      <div class="bg-base-100 rounded-2xl border border-base-300 shadow-sm p-6 sm:p-8 mb-6">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div>
            <h1 class="text-3xl sm:text-4xl font-extrabold mb-1">{t.name}</h1>
          </div>
          <a href={t.external_url} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm gap-1">
            Visit site
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
        <p class="mt-4 text-base-content/70 leading-relaxed">{t.description}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Features -->
        <div class="bg-base-100 rounded-2xl border border-base-300 shadow-sm p-6">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Features
          </h2>
          <ul class="space-y-2">
            {t.features.map((feature) => (
              <li class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-success mt-0.5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm text-base-content/70">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Compatible Plans -->
        <div class="bg-base-100 rounded-2xl border border-base-300 shadow-sm p-6">
          <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Compatible Plans ({compatiblePlans.length})
          </h2>
          {compatiblePlans.length > 0 ? (
            <div class="space-y-2">
              {compatiblePlans.map((plan) => (
                <a href={`/plans/${plan.data.slug}/`} class="flex items-center justify-between p-3 rounded-xl border border-base-300 hover:border-primary/30 hover:bg-primary/5 transition-all duration-200 group">
                  <div>
                    <span class="font-semibold text-sm group-hover:text-primary transition-colors">{plan.data.name}</span>
                    <p class="text-xs text-base-content/50">{plan.data.provider}</p>
                  </div>
                  <span class={`text-sm font-bold ${plan.data.price_monthly === 0 ? 'text-success' : 'text-base-content'}`}>
                    {plan.data.price_monthly === 0 ? 'Free' : `$${plan.data.price_monthly}/mo`}
                  </span>
                </a>
              ))}
            </div>
          ) : (
            <p class="text-sm text-base-content/50">No plan compatibility data available yet.</p>
          )}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
