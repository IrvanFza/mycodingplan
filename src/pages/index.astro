---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PlanCard from '../components/PlanCard.astro';
import RecommendationWizard from '../components/RecommendationWizard.tsx';
import { getCollection } from 'astro:content';

const allPlans = await getCollection('plans');

// Sort: FREE first, then PROMO, then by price
const sortedPlans = [...allPlans].sort((a, b) => {
  const badgeOrder = { FREE: 0, PROMO: 1, PAID: 2 };
  const orderDiff = badgeOrder[a.data.badge] - badgeOrder[b.data.badge];
  if (orderDiff !== 0) return orderDiff;
  return a.data.price_monthly - b.data.price_monthly;
});

const freePlans = allPlans.filter(p => p.data.badge === 'FREE');

// Free-Tier Maximizer: group free plans by complementary capabilities
const freePlanData = freePlans.map(p => p.data);

// Curated free stacks (combining complementary free tools)
const freeStacks = [
  {
    title: 'Code Completion + Chat Stack',
    plans: freePlanData.filter(p => ['chatgpt-plus-free', 'windsurf-free', 'ollama-free'].includes(p.slug)),
    description: 'Combine chat-based AI with local models for a complete $0/mo setup',
  },
  {
    title: 'Google Ecosystem Stack',
    plans: freePlanData.filter(p => ['google-developer-program', 'chatgpt-plus-free'].includes(p.slug)),
    description: 'Leverage Google\'s free developer tools alongside ChatGPT',
  },
  {
    title: 'Privacy-First Stack',
    plans: freePlanData.filter(p => ['ollama-free', 'windsurf-free'].includes(p.slug)),
    description: 'Run everything locally with zero data sharing',
  },
].filter(s => s.plans.length >= 2);

// Serialize plan data for the wizard React island
const planDataForWizard = allPlans.map(plan => ({
  name: plan.data.name,
  slug: plan.data.slug,
  provider: plan.data.provider,
  badge: plan.data.badge,
  price_monthly: plan.data.price_monthly,
  promotional_price: plan.data.promotional_price ?? null,
  description: plan.data.description,
  models: plan.data.models,
  limits: {
    requests_per_minute: plan.data.limits.requests_per_minute ?? null,
    tokens_per_minute: plan.data.limits.tokens_per_minute ?? null,
    context_window: plan.data.limits.context_window ?? null,
    daily_message_limit: plan.data.limits.daily_message_limit ?? null,
  },
  features: plan.data.features,
  categories: plan.data.categories,
  student_discount: plan.data.student_discount,
  startup_credits: plan.data.startup_credits,
  tools_compatible: plan.data.tools_compatible,
  community_score: plan.data.community_score ?? undefined,
  latency: plan.data.latency ? {
    average_ms: plan.data.latency.average_ms,
    uptime_percent: plan.data.latency.uptime_percent,
  } : undefined,
}));

// Unique categories across all plans
const allCategories = [...new Set(allPlans.flatMap(p => p.data.categories))].sort();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'MyCodingPlan',
  url: 'https://mycodingplan.com',
  description: 'Compare AI coding plans and find your perfect setup. Browse free and paid AI coding subscriptions, models, and tools.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://mycodingplan.com/plans/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="Compare AI Coding Plans & Find Your Perfect Setup"
  description="Compare 25+ AI coding plans side-by-side. Find the best free and paid subscriptions for tools like Cursor, Copilot, Claude, and more."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <Navbar />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-primary/5 via-base-100 to-secondary/5 min-h-[calc(100dvh-3.5rem)] flex items-center justify-center py-16 sm:py-24">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-secondary/10 rounded-full blur-3xl"></div>
      </div>
      <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold mb-6 tracking-wide">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          {allPlans.length} PLANS COMPARED
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6">
          Find Your Perfect <br class="hidden sm:block" />
          <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">AI Coding Plan</span>
        </h1>
        <p class="text-lg sm:text-xl text-base-content/60 max-w-2xl mx-auto mb-8 leading-relaxed">
          Compare free and paid AI coding subscriptions side-by-side. From Cursor to Copilot, Claude to Gemini — discover the plan that matches your workflow and budget.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="#wizard" class="btn btn-primary btn-lg gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            Get Recommendations
          </a>
          <a href="#plans" class="btn btn-outline btn-lg gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Browse Plans
          </a>
          <a href="/compare" class="btn btn-outline btn-lg gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Compare Plans
          </a>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-16 bg-base-200/30">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-center mb-10">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-lg mb-2">Browse & Search</h3>
            <p class="text-sm text-base-content/60">Explore 25+ AI coding plans with detailed pricing, models, and feature comparisons.</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-secondary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="font-bold text-lg mb-2">Compare Side-by-Side</h3>
            <p class="text-sm text-base-content/60">Put plans head-to-head with our comparison tool to see pricing, limits, and features at a glance.</p>
          </div>
          <div class="text-center">
            <div class="w-14 h-14 bg-accent/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="font-bold text-lg mb-2">Choose & Code</h3>
            <p class="text-sm text-base-content/60">Pick the plan that fits your budget and workflow, then start coding with AI-powered tools.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Recommendation Wizard -->
    <section id="wizard" class="py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <RecommendationWizard client:visible plans={planDataForWizard} />
      </div>
    </section>

    <!-- Free-Tier Maximizer -->
    {freeStacks.length > 0 && (
      <section class="py-16 bg-base-200/30">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-2xl font-bold mb-2">💸 Free-Tier Maximizer</h2>
            <p class="text-base-content/60 text-sm max-w-2xl mx-auto">
              Combine multiple free-tier plans for a complete AI coding setup at $0/month. These curated stacks pair complementary tools for maximum coverage.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {freeStacks.map((stack) => (
              <div class="bg-base-100 rounded-2xl border border-success/20 shadow-sm p-6 hover:shadow-lg transition-shadow duration-300">
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-bold text-sm">{stack.title}</h3>
                  <span class="badge badge-success badge-sm font-bold">$0/mo</span>
                </div>
                <p class="text-xs text-base-content/50 mb-4">{stack.description}</p>
                <div class="space-y-2">
                  {stack.plans.map((plan) => (
                    <a href={`/plans/${plan.slug}/`} class="flex items-center gap-2 text-sm hover:text-primary transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-success shrink-0" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      {plan.name}
                      <span class="text-xs text-base-content/30">({plan.provider})</span>
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Featured Free Plans -->
    {freePlans.length > 0 && (
      <section class="py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between mb-8">
            <div>
              <h2 class="text-2xl font-bold">🆓 Free Plans</h2>
              <p class="text-sm text-base-content/60 mt-1">Start coding with AI for $0/month</p>
            </div>
            <a href="/plans" class="btn btn-ghost btn-sm gap-1">
              View all
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {freePlans.map((plan) => (
              <PlanCard
                name={plan.data.name}
                slug={plan.data.slug}
                provider={plan.data.provider}
                badge={plan.data.badge}
                price_monthly={plan.data.price_monthly}
                promotional_price={plan.data.promotional_price}
                models={plan.data.models}
                community_score={plan.data.community_score}
                description={plan.data.description}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- All Plans Directory -->
    <section id="plans" class="py-16 bg-base-200/30">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
          <div>
            <h2 class="text-2xl font-bold">All Plans</h2>
            <p class="text-sm text-base-content/60 mt-1">{allPlans.length} plans available</p>
          </div>
        </div>

        <!-- Category Quick-Filter Pills -->
        <div class="flex flex-wrap gap-2 mb-6" id="filter-pills">
          <button class="btn btn-sm btn-primary filter-pill active" data-filter="all">All</button>
          <button class="btn btn-sm btn-ghost filter-pill" data-filter="FREE">Free</button>
          <button class="btn btn-sm btn-ghost filter-pill" data-filter="PROMO">Promo</button>
          <button class="btn btn-sm btn-ghost filter-pill" data-filter="PAID">Paid</button>
        </div>

        <!-- Search -->
        <div class="mb-6">
          <div class="relative max-w-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 absolute left-3 top-1/2 -translate-y-1/2 text-base-content/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              id="plan-search"
              placeholder="Search plans by name, provider, or feature..."
              class="input input-bordered w-full pl-10"
            />
          </div>
        </div>

        <!-- Plan Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="plan-grid">
          {sortedPlans.map((plan) => (
            <div class="plan-item" data-badge={plan.data.badge} data-name={plan.data.name.toLowerCase()} data-provider={plan.data.provider.toLowerCase()} data-features={plan.data.features.join(' ').toLowerCase()}>
              <PlanCard
                name={plan.data.name}
                slug={plan.data.slug}
                provider={plan.data.provider}
                badge={plan.data.badge}
                price_monthly={plan.data.price_monthly}
                promotional_price={plan.data.promotional_price}
                models={plan.data.models}
                community_score={plan.data.community_score}
                description={plan.data.description}
              />
            </div>
          ))}
        </div>

        <div id="no-results" class="hidden text-center py-12">
          <p class="text-base-content/50 text-lg">No plans match your search.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Client-side filtering
  const filterPills = document.querySelectorAll('.filter-pill');
  const searchInput = document.getElementById('plan-search') as HTMLInputElement;
  const planGrid = document.getElementById('plan-grid')!;
  const planItems = document.querySelectorAll('.plan-item') as NodeListOf<HTMLElement>;
  const noResults = document.getElementById('no-results')!;

  let activeFilter = 'all';

  function applyFilters() {
    const query = searchInput?.value.toLowerCase().trim() || '';
    let visibleCount = 0;

    planItems.forEach((item) => {
      const badge = item.dataset.badge || '';
      const name = item.dataset.name || '';
      const provider = item.dataset.provider || '';
      const features = item.dataset.features || '';

      const matchesFilter = activeFilter === 'all' || badge === activeFilter;
      const matchesSearch = !query || name.includes(query) || provider.includes(query) || features.includes(query);

      if (matchesFilter && matchesSearch) {
        item.style.display = '';
        visibleCount++;
      } else {
        item.style.display = 'none';
      }
    });

    noResults.classList.toggle('hidden', visibleCount > 0);
    planGrid.classList.toggle('hidden', visibleCount === 0);
  }

  filterPills.forEach((pill) => {
    pill.addEventListener('click', () => {
      filterPills.forEach((p) => {
        p.classList.remove('btn-primary');
        p.classList.add('btn-ghost');
      });
      pill.classList.remove('btn-ghost');
      pill.classList.add('btn-primary');
      activeFilter = (pill as HTMLElement).dataset.filter || 'all';
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', applyFilters);
</script>