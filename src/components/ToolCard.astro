---
interface Props {
  name: string;
  slug: string;
  description: string;
  plans_compatible: string[];
}

const { name, slug, description, plans_compatible } = Astro.props;

const compatCount = plans_compatible.length;
---

<a href={`/tools/${slug}/`} class="tool-card card bg-base-100 border border-base-300 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group" id={`tool-card-${slug}`}>
  <div class="card-body p-5">
    <!-- Header -->
    <div class="flex items-start justify-between gap-2">
      <div class="flex-1 min-w-0">
        <h3 class="card-title text-base font-bold group-hover:text-primary transition-colors duration-200 leading-tight">{name}</h3>
      </div>
      <div class="badge badge-outline badge-sm font-medium shrink-0">
        {compatCount} {compatCount === 1 ? 'plan' : 'plans'}
      </div>
    </div>

    <!-- Description -->
    <p class="text-sm text-base-content/60 mt-2 line-clamp-3 leading-relaxed">{description}</p>

    <!-- Footer -->
    <div class="flex items-center justify-end mt-3 pt-3 border-t border-base-200">
      <span class="text-xs font-medium text-primary group-hover:translate-x-1 transition-transform duration-200 flex items-center gap-1">
        View details
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
