---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import CompatibilityMatrix from '../../components/CompatibilityMatrix.astro';
import { getCollection } from 'astro:content';

const allTools = await getCollection('tools');

// Sort by name
const sortedTools = [...allTools].sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="AI Coding Tools & IDEs — Compatibility Guide"
  description="Explore AI coding tools and IDEs. Find which tools are compatible with your preferred AI coding plan. Compare Cursor, VS Code, JetBrains, and more."
>
  <Navbar />

  <main class="min-h-screen">
    <!-- Header -->
    <section class="bg-gradient-to-br from-primary/5 via-base-100 to-secondary/5 py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumbs -->
        <nav aria-label="Breadcrumb" class="mb-6">
          <ol class="flex items-center gap-2 text-sm">
            <li><a href="/" class="text-base-content/50 hover:text-primary transition-colors">Home</a></li>
            <li class="text-base-content/30">/</li>
            <li class="font-medium">Tools</li>
          </ol>
        </nav>
        <h1 class="text-3xl sm:text-4xl font-extrabold mb-2">AI Coding Tools & IDEs</h1>
        <p class="text-base-content/60 max-w-2xl">
          Browse {allTools.length} coding tools and IDEs. Discover which AI plans are compatible with your favorite development environment.
        </p>
      </div>
    </section>

    <!-- Compatibility Matrix -->
    <section class="py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <CompatibilityMatrix />
      </div>
    </section>

    <!-- Grid -->
    <section class="py-8 bg-base-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold mb-1">All Tools</h2>
            <p class="text-sm text-base-content/60">
              <span class="font-semibold text-base-content">{allTools.length}</span> tools available
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {sortedTools.map((tool) => (
            <ToolCard
              name={tool.data.name}
              slug={tool.data.slug}
              description={tool.data.description}
              plans_compatible={tool.data.plans_compatible}
            />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
